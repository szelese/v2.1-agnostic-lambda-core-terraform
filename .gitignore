# =================================================================
# PYTHON ARTIFACTS
# =================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =================================================================
# VIRTUAL ENVIRONMENTS
# =================================================================
.venv/
venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt

# =================================================================
# SECURITY AND ENVIRONMENTAL VARIABLES (Security First)
# =================================================================
# Local environment variables files
.env
.env.local
.env.test
.env.production

# Secret keys and certificate files
*.pem
*.key
*.pub
*.crt
*.pfx

# AWS CLI local configuration (NEVER! leak account ID)
.aws/
credentials
config

# =================================================================
# TERRAFORM (Infrastructure as Code)
# =================================================================
# Local state files (NEVER! commit - contains sensitive resource data)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output (may contain sensitive variable values)
*.tfplan
*.tfplan.*

# Crash and debug logs generated by Terraform
crash.log
crash.*.log

# Terraform variable files with actual values (use .tfvars.example instead)
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.tfvars.json.example

# Terraform CLI and provider cache (auto-generated, OS-specific)
.terraform/
.terraform.lock.hcl

# Terragrunt cache
.terragrunt-cache/

# =================================================================
# IDE / EDITORS (VS Code, PyCharm, OS)
# =================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# =================================================================
# DOCKER
# =================================================================
.docker/
*.log
docker-compose.override.yml

# =================================================================
# DATA, DOCUMENTATION AND DIAGNOSIS
# =================================================================
# If you download data for testing, do not include it in the repository
data/*.csv
data/*.json
data/*.parquet
!data/.gitkeep

# Performance and test reports
reports/
locust_reports/
*.html